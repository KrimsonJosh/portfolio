---
import BaseLayout from "../layouts/BaseLayout.astro"
import ContentContainer from "../components/ContentContainer.astro"

const pageTitle = "Contact";
---

<BaseLayout pageTitle={pageTitle}>
    <ContentContainer align="center">
        <section class="contact-hero">
            <h1 class="contact-title">Get in Touch</h1>
            <div class="contact-content">
                <p class="intro">I’d love to connect. You can reach me directly at:</p>
                <ul class="contact-details">
                    <li>Email: <a href="mailto:joshuamoinzadeh@gmail.com">joshuamoinzadeh@gmail.com</a></li>
                    <li>Phone: <a href="tel:8179752705">+1 (817) 975-2705</a></li>
                </ul>
            </div>
        </section>
    </ContentContainer>
</BaseLayout>

<style>
    .contact-hero {
        padding: 4rem 0;
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
    }

    .contact-title {
        font-size: clamp(2.5rem, 5vw, 4rem);
        margin-bottom: 1.5rem;
        font-weight: 800;
        background: linear-gradient(90deg, #36314a 0%, #7873f5 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .contact-content {
        margin-top: 1.5rem;
        color: var(--text-2);
    }

    .intro {
        font-size: 1.2rem;
        line-height: 1.7;
        margin-bottom: 2rem;
    }

    .contact-form {
        display: grid;
        gap: 1.25rem;
        text-align: left;
    }

    .contact-form label {
        display: grid;
        gap: 0.5rem;
        font-size: 0.95rem;
        color: var(--text-1);
    }

    .contact-form input,
    .contact-form textarea {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.8rem;
        background: var(--surface-1);
        color: var(--text-1);
        font-size: 1rem;
    }

    .contact-form button {
        width: fit-content;
        border: none;
        border-radius: 8px;
        padding: 0.75rem 1.2rem;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        background: linear-gradient(120deg, #5d5fe5 0%, #6f8fff 100%);
        color: white;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .contact-form button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    }

    @media (max-width: 768px) {
        .contact-title {
            font-size: 2.5rem;
        }

        .intro {
            font-size: 1.1rem;
        }
    }
</style>
